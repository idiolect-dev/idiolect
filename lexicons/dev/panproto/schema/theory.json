{
  "lexicon": 1,
  "id": "dev.panproto.schema.theory",
  "defs": {
    "main": {
      "type": "record",
      "key": "tid",
      "record": {
        "type": "object",
        "required": ["name", "objectHash", "createdAt"],
        "properties": {
          "name": { "type": "string", "maxLength": 256 },
          "extends": {
            "type": "array",
            "items": { "type": "string", "maxLength": 256 },
            "maxLength": 20
          },
          "sortCount": { "type": "integer" },
          "opCount": { "type": "integer" },
          "eqCount": { "type": "integer" },
          "directedEqCount": { "type": "integer" },
          "policyCount": { "type": "integer" },
          "morphismCount": { "type": "integer" },
          "classCount": { "type": "integer" },
          "instanceCount": { "type": "integer" },
          "inductiveCount": { "type": "integer" },
          "objectHash": { "type": "string", "maxLength": 64 },
          "blob": { "type": "blob", "accept": ["application/x-msgpack"], "maxSize": 1048576 },
          "createdAt": { "type": "string", "format": "datetime" }
        }
      }
    }
  }
}
