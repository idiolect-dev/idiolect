# rust
/target
**/*.rs.bk
Cargo.lock.bak

# bun / node
node_modules/
.pnp.*
dist/
build/
*.tsbuildinfo

# generated code is committed on purpose: idiolect-codegen owns the
# content and a drift gate in ci ensures it stays in sync with the
# lexicons. see crates/idiolect-codegen/moon.yml.
**/.lex/

# moon
.moon/cache/
.moon/docker/

# editors
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# env
.env
.env.local
.env.*.local

# dev
notes/

# claude code runtime state
.claude/

# Build artefact: packages/schema/scripts/copy-lexicons.ts copies
# the workspace-root lexicons/ tree here so loadLexiconDocs
# resolves it via import.meta.url-relative paths in both dev and
# published builds. The workspace root is the source of truth.
packages/schema/lexicons/

# Build artefact: copy-lexicons.ts also bakes the lexicon JSON
# into a TS module (bundledLexiconDocs) so browser consumers
# work without node:fs. Regenerated on every build / pretest.
packages/schema/src/generated-lexicons.ts
